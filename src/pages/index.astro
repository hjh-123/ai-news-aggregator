---
import Database from 'better-sqlite3';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const dbPath = join(__dirname, '..', '..', 'data', 'news.db');

let news = [];
try {
  const db = new Database(dbPath, { readonly: true });
  news = db.prepare(`
    SELECT id, title, link, summary, source, category, published_at, ai_summary, tags
    FROM news
    ORDER BY published_at DESC
    LIMIT 50
  `).all();
  db.close();
} catch (e) {
  console.error('数据库读取失败:', e.message);
}

const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', { 
    month: 'short', 
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};

const categoryColors = {
  company: 'bg-blue-100 text-blue-800',
  media: 'bg-green-100 text-green-800',
  community: 'bg-purple-100 text-purple-800',
  research: 'bg-orange-100 text-orange-800',
};

const categoryNames = {
  company: '公司动态',
  media: '媒体报道',
  community: '社区',
  research: '研究论文',
};
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI 新闻聚合</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <!-- Header -->
      <header class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">
          🤖 AI 新闻聚合
        </h1>
        <p class="text-gray-600">
          自动收集全球最新 AI 动态 · 每小时更新
        </p>
        <div class="mt-4 flex gap-2">
          {Object.entries(categoryNames).map(([key, name]) => (
            <span class={`px-3 py-1 rounded-full text-sm ${categoryColors[key]}`}>
              {name}
            </span>
          ))}
        </div>
      </header>

      <!-- News List -->
      <main class="space-y-4">
        {news.length === 0 ? (
          <div class="text-center py-12 text-gray-500">
            <p>暂无新闻，等待首次抓取...</p>
          </div>
        ) : (
          news.map((item) => (
            <article class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h2 class="text-xl font-semibold text-gray-900">
                  <a 
                    href={item.link} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="hover:text-blue-600 transition-colors"
                  >
                    {item.title}
                  </a>
                </h2>
              </div>
              
              <div class="flex items-center gap-3 mb-3">
                <span class={`px-2 py-1 rounded text-xs font-medium ${categoryColors[item.category]}`}>
                  {categoryNames[item.category]}
                </span>
                <span class="text-sm text-gray-500">{item.source}</span>
                <span class="text-sm text-gray-400">·</span>
                <span class="text-sm text-gray-400">{formatDate(item.published_at)}</span>
              </div>
              
              {item.summary && (
                <p class="text-gray-600 text-sm line-clamp-3">
                  {item.summary}
                </p>
              )}
              
              <div class="mt-4">
                <a 
                  href={item.link} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="text-blue-600 text-sm font-medium hover:underline"
                >
                  阅读全文 →
                </a>
              </div>
            </article>
          ))
        )}
      </main>

      <!-- Footer -->
      <footer class="mt-12 pt-8 border-t border-gray-200 text-center text-gray-500 text-sm">
        <p>数据每小时自动更新 · Powered by Astro + GitHub Actions</p>
      </footer>
    </div>
  </body>
</html>
